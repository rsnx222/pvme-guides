{
  "version": "0.2",
  "language": "en-GB",

  "import": [
    "@cspell/dict-software-terms/cspell-ext.json",
    "@cspell/dict-gaming-terms/cspell-ext.json"
  ],

  "dictionaryDefinitions": [
    {
      "name": "pvme-words",
      "path": "./allow.txt"
    }
  ],

  "dictionaries": ["pvme-words", "en-gb"],

  "files": ["**/*.txt"],

  "flagWords": ["./reject.txt"],

  "ignorePaths": [
    "node_modules/**",
    ".git/**",

    ".github/**",
    ".vscode/**",
    "archive/**",
    "ca-bingo-lists/**",

    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.gif",
    "**/*.webp",
    "**/*.pdf",
    "**/*.zip",
    "**/*.mp3",
    "**/*.mp4",

    "**/mental-health.txt",
    "**/contributors.txt",
    "archive/**"
  ],

  "ignoreRegExpList": [
    "<:.*?:.*?>",
    "\\`([^\\`].*?)\\`",
    "https?:\\/\\/[^\\s]+",
    "\\.tag:\\w*",
    "\\!\\.\\w*",
    "\\$.*\\$",
    "```[\\s\\S]*?```"
  ]
}
