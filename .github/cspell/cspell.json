{
  "version": "0.2",
  "language": "en-GB",

  "files": [
    "**/*.txt",

    "!archive/**",
    "!ca-bingo-lists/**",
    "!.github/**",
    "!.vscode/**",
    "!node_modules/**",
    "!.git/**",

    "!**/mental-health.txt",
    "!**/contributors.txt"
  ],

  "import": [
    "@cspell/dict-software-terms/cspell-ext.json",
    "@cspell/dict-gaming-terms/cspell-ext.json"
  ],

  "dictionaryDefinitions": [
    {
      "name": "pvme-words",
      "path": "./allow.txt"
    }
  ],

  "dictionaries": ["pvme-words", "en-gb"],

  "flagWords": ["./reject.txt"],

  "ignoreRegExpList": [
    "<:.*?:.*?>",
    "\\`([^\\`].*?)\\`",
    "https?:\\/\\/[^\\s]+",
    "\\.tag:\\w*",
    "\\!\\.\\w*",
    "\\$.*\\$",
    "```[\\s\\S]*?```"
  ]
}
